---
// Configuración: solo superadmin (datos de usuario + escuela + sucursales/albercas)
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import SettingsView from '@/components/SettingsView';

const { supabase, session } = Astro.locals;

if (session!.profile.role !== 'superadmin') return Astro.redirect('/dashboard');

const [orgQ, branchesQ, poolsQ] = await Promise.all([
  supabase
    .from('org_settings')
    .select('school_name, phone, email, logo_url, theme')
    .eq('id', true)
    .single(),
  supabase.from('branches').select('id, name, address, phone, is_active').order('name'),
  supabase.from('pools').select('id, name, lanes, branch_id').order('name'),
]);

const org = orgQ.data ?? {
  school_name: 'Escuela de Natación',
  phone: null,
  email: null,
  logo_url: null,
  theme: 'ocean',
};

const user = {
  full_name: session!.profile.full_name,
  phone: session!.profile.phone,
  email: session!.user.email ?? '',
  role: session!.profile.role,
};
---

<DashboardLayout title="Configuración">
  <SettingsView
    client:load
    org={org}
    branches={branchesQ.data ?? []}
    pools={poolsQ.data ?? []}
    user={user}
  />
</DashboardLayout>
