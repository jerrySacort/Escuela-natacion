---
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const { supabase } = Astro.locals;

// RLS filtra automáticamente por sucursal según el rol
const [{ count: students }, { count: groups }, { count: pendingCharges }] =
  await Promise.all([
    supabase.from('students').select('*', { count: 'exact', head: true }).eq('is_active', true),
    supabase.from('groups').select('*', { count: 'exact', head: true }).eq('is_active', true),
    supabase.from('charges').select('*', { count: 'exact', head: true }).eq('status', 'pending'),
  ]);

const cards = [
  { label: 'Alumnos activos', value: students ?? 0 },
  { label: 'Grupos activos', value: groups ?? 0 },
  { label: 'Cargos pendientes', value: pendingCharges ?? 0 },
];
---

<DashboardLayout title="Panel general">
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    {
      cards.map((c) => (
        <div class="rounded-lg bg-white p-6 shadow-sm">
          <p class="text-sm text-slate-500">{c.label}</p>
          <p class="mt-1 text-3xl font-bold text-brand-700">{c.value}</p>
        </div>
      ))
    }
  </div>
</DashboardLayout>
