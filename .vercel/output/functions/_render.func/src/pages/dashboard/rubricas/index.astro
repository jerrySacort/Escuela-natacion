---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import RubricsView from '@/components/RubricsView';

const { supabase, session } = Astro.locals;
const canEdit = session!.profile.role === 'superadmin';

const [levelsQ, skillsQ] = await Promise.all([
  supabase.from('levels').select('id, name, description').order('sort_order'),
  supabase.from('skills').select('id, level_id, name, sort_order'),
]);
---

<DashboardLayout title="Rúbricas por nivel">
  {
    !canEdit && (
      <p class="-mt-2 mb-5 text-sm text-white/40">
        Solo lectura — el superadmin administra el catálogo.
      </p>
    )
  }
  <RubricsView
    client:load
    levels={levelsQ.data ?? []}
    skills={skillsQ.data ?? []}
    canEdit={canEdit}
  />
</DashboardLayout>
