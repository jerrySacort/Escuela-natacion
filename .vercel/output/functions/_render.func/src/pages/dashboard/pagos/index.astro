---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PaymentsView from '@/components/PaymentsView';

const { supabase, session } = Astro.locals;
const role = session!.profile.role;
const canManage = ['superadmin', 'branch_admin', 'coordinator'].includes(role);

const { data: charges } = await supabase
  .from('charges')
  .select(
    'id, student_id, concept, amount_due, due_date, status, students(first_name, last_name), enrollments(groups(name))',
  )
  .order('due_date', { ascending: false })
  .limit(300);

const one = <T,>(v: T | T[] | null): T | null =>
  Array.isArray(v) ? (v[0] ?? null) : v;

const rows = (charges ?? []).map((c) => {
  const s = one(c.students) as { first_name: string; last_name: string } | null;
  const enr = one(c.enrollments) as { groups: unknown } | null;
  const g = one(enr?.groups ?? null) as { name: string } | null;
  return {
    id: c.id,
    student_id: c.student_id,
    student_name: s ? `${s.last_name}, ${s.first_name}` : '—',
    group_name: g?.name ?? null,
    concept: c.concept,
    amount_due: Number(c.amount_due),
    due_date: c.due_date,
    status: c.status as 'pending' | 'overdue' | 'paid' | 'cancelled',
  };
});
---

<DashboardLayout title="Pagos y cobranza">
  <PaymentsView client:load charges={rows} canManage={canManage} />
</DashboardLayout>
