---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import InstructorsView from '@/components/InstructorsView';

const { supabase, session } = Astro.locals;
const role = session!.profile.role;
const isSuperadmin = role === 'superadmin';
const canManage = ['superadmin', 'branch_admin'].includes(role);

const [instructorsQ, branchesQ, groupsQ] = await Promise.all([
  supabase
    .from('instructors')
    .select(
      'id, profile_id, branch_id, specialties, certifications, hourly_rate, hired_at, is_active, profiles(full_name, phone), branches(name)',
    ),
  isSuperadmin
    ? supabase.from('branches').select('id, name').eq('is_active', true).order('name')
    : Promise.resolve({ data: [] as { id: string; name: string }[] }),
  supabase.from('groups').select('instructor_id').eq('is_active', true),
]);

const one = <T,>(v: T | T[] | null): T | null =>
  Array.isArray(v) ? (v[0] ?? null) : v;

const groupCounts = new Map<string, number>();
for (const g of groupsQ.data ?? []) {
  if (g.instructor_id) {
    groupCounts.set(g.instructor_id, (groupCounts.get(g.instructor_id) ?? 0) + 1);
  }
}

const instructors = (instructorsQ.data ?? [])
  .map((i) => {
    const p = one(i.profiles) as { full_name: string; phone: string | null } | null;
    return {
      id: i.id,
      profile_id: i.profile_id,
      branch_id: i.branch_id,
      name: p?.full_name ?? '—',
      phone: p?.phone ?? null,
      specialties: (i.specialties ?? []) as string[],
      certifications: (i.certifications ?? []) as string[],
      hourly_rate: i.hourly_rate !== null ? Number(i.hourly_rate) : null,
      hired_at: i.hired_at,
      is_active: i.is_active,
      branch_name: (one(i.branches) as { name: string } | null)?.name ?? '—',
      groups_count: groupCounts.get(i.id) ?? 0,
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name));
---

<DashboardLayout title="Instructores">
  <InstructorsView
    client:load
    instructors={instructors}
    branches={branchesQ.data ?? []}
    showBranchSelect={isSuperadmin}
    canManage={canManage}
  />
</DashboardLayout>
